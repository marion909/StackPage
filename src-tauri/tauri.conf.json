{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StackPage",
  "version": "1.0.3",
  "identifier": "com.stackpage.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StackPage",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "copyright": "© 2025 StackPage",
    "shortDescription": "Visual website builder",
    "longDescription": "StackPage is a drag-and-drop visual website builder that generates clean HTML, CSS and JavaScript. Design pages with reusable blocks, export static sites, and publish via FTP or Netlify — all from a native desktop app.",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["English", "German"]
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxMjM3OTdERUEyQThFN0YKUldSL2ppcnFmWGtqTVpjWlg0VkJySWM3TVJkVGd5TDFNbDlzMVJhVW1OTzN1SE5wdmxBbVNJeGkK",
      "endpoints": [
        "https://stackpage.at/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
